datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  category    String
  material    String
  image       String
  description String
  createdAt   DateTime @default(now())
}